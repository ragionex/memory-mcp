{
  "name": "@ragionex/memory-mcp",
  "version": "0.5.0",
  "description": "MCP server for Ragionex Memory - persistent memory for AI agents.",
  "license": "MIT",
  "homepage": "https://ragionex.com/memory/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ragionex/memory-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/ragionex/memory-mcp/issues",
    "email": "contact@ragionex.com"
  },
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "ragionex-memory-mcp": "build/index.js"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "prepublishOnly": "npm run build",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "typescript": "5.9.3"
  }
}
